   "source": [
    "#plot the total count of wildfires occuring each year \n",
    "# Create the line plot\n",
    "ax = sea.lineplot(data=yearly_counts, x='Year', y='Total_Incidents')\n",
    "\n",
    "# Set the title and axis labels\n",
    "ax.set(title='Total Wildfires per Year', xlabel='Year', ylabel='Total Incidents')\n",
    "\n",
    "# set up data and create polynomial for trendline\n",
    "x = yearly_counts['Year']\n",
    "y = yearly_counts['Total_Incidents']\n",
    "\n",
    "z = np.polyfit(x, y, 1)  # Linear fit (degree 1)\n",
    "p = np.poly1d(z)\n",
    "\n",
    "# Generate x values for the trend line\n",
    "x_fit = np.linspace(x.min(), x.max(), 100)\n",
    "y_fit = p(x_fit)\n",
    "\n",
    "# Plot the trend line\n",
    "plt.plot(x_fit, y_fit, color='red', linestyle='--', label='Trend Line')\n",
    "\n",
    "plt.show()"
   ]
  },
