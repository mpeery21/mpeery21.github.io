   "source": [
    "#replacing the values in the Cause column to be strings instead of object\n",
    "fires['Cause'] = fires['Cause'].astype('string')\n",
    "\n",
    "#replace the number values in 'Cause' to strings\n",
    "# combined \"arson\" and \"playing with fire\" into one category\n",
    "#combined \"campfire\" and \"illegal alien campfire\" into one category\n",
    "fires.loc[fires['Cause'] == '1.0', 'Cause'] = 'Lightning'\n",
    "fires.loc[fires['Cause'] == '2.0', 'Cause'] = 'Equipment Use'\n",
    "fires.loc[fires['Cause'] == '3.0', 'Cause'] = 'Smoking'\n",
    "fires.loc[fires['Cause'] == '4.0', 'Cause'] = 'Campfire'\n",
    "fires.loc[fires['Cause'] == '5.0', 'Cause'] = 'Debris'\n",
    "fires.loc[fires['Cause'] == '6.0', 'Cause'] = 'Railroad'\n",
    "fires.loc[fires['Cause'] == '7.0', 'Cause'] = 'Arson'\n",
    "fires.loc[fires['Cause'] == '8.0', 'Cause'] = 'Arson'\n",
    "fires.loc[fires['Cause'] == '9.0', 'Cause'] = 'Miscellaneous'\n",
    "fires.loc[fires['Cause'] == '10.0', 'Cause'] = 'Vehicle'\n",
    "fires.loc[fires['Cause'] == '11.0', 'Cause'] = 'Powerline'\n",
    "fires.loc[fires['Cause'] == '12.0', 'Cause'] = 'Firefighter Training'\n",
    "fires.loc[fires['Cause'] == '13.0', 'Cause'] = 'Non-firefighter Training'\n",
    "fires.loc[fires['Cause'] == '14.0', 'Cause'] = 'Unknown/Unidentified'\n",
    "fires.loc[fires['Cause'] == '15.0', 'Cause'] = 'Structure'\n",
    "fires.loc[fires['Cause'] == '16.0', 'Cause'] = 'Aircraft'\n",
    "fires.loc[fires['Cause'] == '17.0', 'Cause'] = 'Volcanic'\n",
    "fires.loc[fires['Cause'] == '18.0', 'Cause'] = 'Escaped Prescribed Burn'\n",
    "fires.loc[fires['Cause'] == '19.0', 'Cause'] = 'Campfire'\n",
    "\n",
    "fires\n"
   ]
  },
