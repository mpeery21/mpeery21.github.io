   "source": [
    "# fill in Month column based on both alarm date and containment date columns\n",
    "#some fires have containment date, but not alarm date so this solves that issue\n",
    "fires['Month'] = fires['Alarm Date'].dt.month.combine_first(fires['Containment Date'].dt.month)\n",
    "fires"
   ]
  },
