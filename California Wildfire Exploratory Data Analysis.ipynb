   "source": [
    "#compare top causes of wildfires for all years, excluding wildfires caused by unknown reasons\n",
    "all_years_no_unknown = fires[fires['Cause'] != 'Unknown/Unidentified']\n",
    "\n",
    "\n",
    "cause_counts = all_years_no_unknown.groupby(['Year', 'Cause']).size().reset_index(name='Count')\n",
    "cause_counts\n",
    "\n",
    "#find the top 5 causes for each year\n",
    "top_causes_per_year = (cause_counts.sort_values(by=['Year', 'Count'], ascending=[True, False]).groupby('Year').head(5))\n",
    "top_causes_per_year\n",
    "\n",
    "pivot_df = top_causes_per_year.pivot(index='Year', columns='Cause', values='Count').fillna(0)\n",
    "pivot_df"
   ]
  },
